# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Required for Google Calendar and Gmail OAuth integration.
# Create this in the Google Cloud Console (APIs & Services -> Credentials).
GOOGLE_CLIENT_ID="your_google_client_id"

# GOOGLE_CLIENT_SECRET: Required for Google Calendar and Gmail OAuth integration.
# Create this in the Google Cloud Console (APIs & Services -> Credentials).
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ELEVENLABS_API_KEY: Required for high-quality Text-to-Speech (Backend).
# Add this via the Secrets panel in the AI Studio UI or your hosting provider.
ELEVENLABS_API_KEY="your_elevenlabs_api_key"

# SUPABASE CONFIGURATION
# Add these via the Secrets panel in the AI Studio UI.
VITE_SUPABASE_URL="your_supabase_project_url"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_public_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_secret_key"

# SESSION_SECRET: Required for Express session encryption.
# Generate a random string of at least 32 characters.
SESSION_SECRET="your_random_session_secret_min_32_chars"

# SUPABASE_DB_URL: Direct PostgreSQL connection to Supabase (required for MIMA_SECURITY_V2).
# Get this from Supabase Dashboard → Settings → Database → Connection string.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL="your_supabase_db_connection_string"

# MIMA_SECURITY_V2: Feature flag for security hardening.
# "true" (default): PostgreSQL session store, AES-GCM encryption, strict validation
# "false": Legacy mode (MemoryStore, AES-CBC with static salt) — do not use in production
# MIMA_SECURITY_V2="true"
